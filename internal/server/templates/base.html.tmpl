{{define "base"}}<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="#111111">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="dashboard">
  <title>{{block "title" .}}personal-dashboard{{end}}</title>
  <link rel="manifest" href="/static/manifest.webmanifest">
  <link rel="icon" href="/static/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/static/icon.svg">
  <link rel="stylesheet" href="/static/app.css">
  <script defer src="/static/htmx.min.js"></script>
  <script>
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", () => {
        navigator.serviceWorker.register("/static/sw.js", { scope: "/" });
      });
    }
  </script>
</head>
<body class="{{if .Revealed}}revealed{{end}}">
  <main class="stack">
    {{block "reveal-toggle" .}}
      {{if .Revealed}}
        <form method="post" action="/hide" class="reveal-toggle">
          <input type="hidden" name="route" value="{{.Route}}">
          <input type="hidden" name="next" value="{{.Route}}">
          <button type="submit" class="tap">hide private content</button>
        </form>
      {{else}}
        <form method="post" action="/reveal" class="reveal-toggle">
          <input type="hidden" name="route" value="{{.Route}}">
          <input type="hidden" name="next" value="{{.Route}}">
          <button type="submit" class="tap accent">reveal private content</button>
        </form>
      {{end}}
    {{end}}
    {{block "main" .}}{{end}}
  </main>
</body>
</html>{{end}}
