{{template "base" .}}
{{define "title"}}personal-dashboard{{end}}
{{define "main"}}
<header>
  <h1>personal-dashboard</h1>
  <p class="muted">scaffold + PWA shell. panels land in #43-#48.</p>
</header>
<section class="card">
  <h2>Status</h2>
  <p>Daemon online. PWA shell ready to install (tap "Add to Home Screen").</p>
  <p class="muted">Next: <a href="https://github.com/coilysiren/personal-dashboard/issues/38">#38 systemd deploy</a>, panels <a href="https://github.com/coilysiren/personal-dashboard/issues/43">#43-#48</a>.</p>
</section>
<section class="card">
  <h2>Redaction smoke test</h2>
  <p>Default state: <span class="redactable">private text here</span></p>
</section>
<section class="card">
  <h2>Voice smoke test</h2>
  <p class="muted">Requires ELEVENLABS_API_KEY and ELEVENLABS_VOICE_ID in the daemon env.</p>
  <button type="button" class="tap" onclick="dashboardSay('personal dashboard online')">say hello</button>
</section>
{{end}}
