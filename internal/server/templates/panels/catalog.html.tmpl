{{define "title"}}catalog - personal-dashboard{{end}}
{{define "main"}}
<header>
  <h1>catalog</h1>
  <p class="muted">cross-repo dependency graph from <code>agentic-os-kai/data/catalog-graph.yaml</code>, overlaid with live signals from repo-recall.</p>
</header>

{{with .Panel.Catalog}}
{{if .YamlErr}}
<section class="card">
  <h2>yaml error</h2>
  <p class="muted"><code>{{.YamlErr}}</code></p>
  <p class="muted">graph path: <code>{{.GraphPath}}</code>. Run <code>coily exec build-catalog-graph</code> in agentic-os-kai to regenerate.</p>
</section>
{{else}}

<section class="card catalog-graph">
  <h2>graph</h2>
  {{if .RepoErr}}
    <p class="muted">live overlay degraded: <code>{{.RepoErr}}</code>. graph still renders, badges absent.</p>
  {{end}}
  <div id="cy" class="cy-canvas" role="img" aria-label="cross-repo dependency graph"></div>
  <p class="muted">drag to pan, pinch or scroll to zoom. tap a repo to open its detail below. border green = CI success, red = failure, orange-dashed = running.</p>
</section>

<style>
  .cy-canvas {
    width: 100%;
    height: 70vh;
    min-height: 380px;
    background: #0f0f0f;
    border-radius: 8px;
    overflow: hidden;
    touch-action: none;
  }
  @media (max-width: 720px) {
    .cy-canvas { height: 60vh; }
  }
</style>

<section class="card">
  <h2>systems</h2>
  <p class="muted">tap a repo to expand its detail. live signals come from repo-recall (<code>{{.RepoRecall}}</code>).</p>
  {{range $sys := .Systems}}
  <details class="catalog-system" open>
    <summary><strong>{{$sys}}</strong> <span class="muted">({{len (index $.Panel.Catalog.BySystem $sys)}})</span></summary>
    {{range index $.Panel.Catalog.BySystem $sys}}
    <details class="catalog-node">
      <summary class="catalog-node-summary">
        <span class="catalog-node-name">{{.Name}}</span>
        <span class="catalog-node-type muted">{{.Type}} · {{.Lifecycle}}</span>
        {{if .Live.HaveRow}}
          {{if eq .Live.CIStatus "failure"}}<span class="badge bad">ci fail</span>{{end}}
          {{if eq .Live.CIStatus "running"}}<span class="badge warn">ci running</span>{{end}}
          {{if eq .Live.CIStatus "success"}}<span class="badge ok">ci ok</span>{{end}}
          {{if .Live.OpenIssues}}<span class="badge">{{.Live.OpenIssues}} issues</span>{{end}}
          {{if .Live.OpenPRs}}<span class="badge">{{.Live.OpenPRs}} prs</span>{{end}}
          {{if .Live.ActionRequired}}<span class="badge warn">action</span>{{end}}
        {{else}}
          <span class="badge muted">no repo-recall row</span>
        {{end}}
      </summary>
      <div class="catalog-node-body">
        <p>{{.Description}}</p>
        <dl>
          <dt>kind</dt><dd>{{.Kind}} · {{.Type}} · {{.Lifecycle}}</dd>
          <dt>owner</dt><dd>{{.Owner}}</dd>
          {{if .DependsOn}}<dt>depends on</dt><dd>{{range $i, $d := .DependsOn}}{{if $i}}, {{end}}<code>{{lastSeg $d}}</code>{{end}}</dd>{{end}}
          {{if .DependedBy}}<dt>depended by</dt><dd>{{range $i, $d := .DependedBy}}{{if $i}}, {{end}}<code>{{lastSeg $d}}</code>{{end}}</dd>{{end}}
          {{if .ProvidesApis}}<dt>provides</dt><dd>{{range $i, $a := .ProvidesApis}}{{if $i}}, {{end}}<code>{{$a}}</code>{{end}}</dd>{{end}}
          {{if .ConsumesApis}}<dt>consumes</dt><dd>{{range $i, $a := .ConsumesApis}}{{if $i}}, {{end}}<code>{{$a}}</code>{{end}}</dd>{{end}}
          {{if .Live.HaveRow}}
            <dt>activity</dt><dd>{{.Live.Commits30d}} commits / 30d · {{.Live.Authors30d}} authors · score {{printf "%.1f" .Live.ActivityScore}}</dd>
            <dt>branch</dt><dd><code>{{.Live.HeadRef}}</code>{{if ne .Live.HeadRef .Live.DefaultBranch}} (default <code>{{.Live.DefaultBranch}}</code>){{end}}{{if .Live.CommitsAhead}} · {{.Live.CommitsAhead}} ahead{{end}}{{if .Live.CommitsBehind}} · {{.Live.CommitsBehind}} behind{{end}}</dd>
            {{if .Live.ActionSignals}}<dt>signals</dt><dd>{{range $i, $s := .Live.ActionSignals}}{{if $i}}, {{end}}<code>{{$s}}</code>{{end}}</dd>{{end}}
            {{if .Live.IssuesAssignedToMe}}<dt>mine</dt><dd>{{.Live.IssuesAssignedToMe}} issues assigned · {{.Live.PRsAwaitingMyReview}} prs to review</dd>{{end}}
            {{if .Live.DeployStatus}}<dt>deploy</dt><dd><code>{{.Live.DeployStatus}}</code>{{if .Live.DeployWorkflow}} via <code>{{.Live.DeployWorkflow}}</code>{{end}}</dd>{{end}}
            {{if .Live.RemoteURL}}<dt>repo</dt><dd><a href="{{.Live.RemoteURL}}" target="_blank" rel="noopener">{{.Live.RemoteURL}}</a></dd>{{end}}
          {{end}}
        </dl>
      </div>
    </details>
    {{end}}
  </details>
  {{end}}
</section>

<section class="card">
  <h2>refresh</h2>
  <p class="muted">graph regenerates from <code>coily exec build-catalog-graph</code> in agentic-os-kai. live overlay refreshes from repo-recall's scan (default every 5m).</p>
  <p class="row">
    <a class="tap" href="/panels/catalog">reload panel</a>
    <a class="tap" href="/api/catalog">json</a>
    <a class="tap" href="{{.RepoRecall}}" target="_blank" rel="noopener">repo-recall</a>
  </p>
  <p class="muted">generated at {{.GeneratedAt.Format "15:04:05"}}</p>
</section>
{{end}}
{{end}}

<p><a class="tap" href="/">back</a></p>

<script type="module">
  const cy = await import("https://cdn.jsdelivr.net/npm/cytoscape@3.30.4/dist/cytoscape.esm.min.js");
  const fcoseModule = await import("https://cdn.jsdelivr.net/npm/cytoscape-fcose@2.2.0/+esm");
  cy.default.use(fcoseModule.default);

  const res = await fetch("/api/catalog", { cache: "no-store" });
  const data = await res.json();

  // Build elements: one compound parent per system, one child per node,
  // one edge per dependsOn. Edges that point at a bare API name (no "/")
  // are dropped from the visual, since they don't terminate at a node.
  const elements = [];
  const systems = new Set();
  const nodeIDs = new Set();
  for (const n of data.nodes || []) {
    systems.add(n.system || "unsorted");
    nodeIDs.add(n.id);
    elements.push({
      group: "nodes",
      data: {
        id: n.id,
        label: n.name,
        parent: "sys:" + (n.system || "unsorted"),
        type: n.type || "",
        lifecycle: n.lifecycle || "",
        ci: (n.live && n.live.have_row) ? (n.live.ci_status || "") : "",
        openIssues: (n.live && n.live.open_issues) || 0,
        actionRequired: !!(n.live && n.live.action_required),
        description: n.description || "",
      },
    });
  }
  for (const s of systems) {
    elements.push({ group: "nodes", data: { id: "sys:" + s, label: s, isSystem: true } });
  }
  for (const e of data.edges || []) {
    if (e.type !== "dependsOn") continue;
    if (!nodeIDs.has(e.to)) continue;
    elements.push({ group: "edges", data: { source: e.from, target: e.to } });
  }

  const instance = cy.default({
    container: document.getElementById("cy"),
    elements,
    wheelSensitivity: 0.2,
    style: [
      {
        selector: "node",
        style: {
          "label": "data(label)",
          "color": "#eaeaea",
          "font-family": "ui-sans-serif, system-ui, sans-serif",
          "font-size": "11px",
          "text-valign": "center",
          "text-halign": "center",
          "background-color": "#1d4e89",
          "border-color": "#2a6fbb",
          "border-width": 1,
          "shape": "round-rectangle",
          "width": "label",
          "height": 28,
          "padding": "8px",
          "text-wrap": "ellipsis",
          "text-max-width": "140px",
        },
      },
      {
        selector: "node[?isSystem]",
        style: {
          "label": "data(label)",
          "background-color": "rgba(255,255,255,0.03)",
          "background-opacity": 1,
          "border-color": "rgba(255,255,255,0.15)",
          "border-width": 1,
          "shape": "round-rectangle",
          "color": "#9aa",
          "font-size": "12px",
          "font-weight": "bold",
          "text-valign": "top",
          "text-halign": "center",
          "text-margin-y": -6,
          "padding": "18px",
        },
      },
      { selector: 'node[ci = "success"]', style: { "border-color": "#3a3", "border-width": 3 } },
      { selector: 'node[ci = "failure"]', style: { "border-color": "#c33", "border-width": 4 } },
      { selector: 'node[ci = "running"]', style: { "border-color": "#fa3", "border-width": 3, "border-style": "dashed" } },
      { selector: 'node[?actionRequired]', style: { "background-color": "#8a5a1d" } },
      {
        selector: "edge",
        style: {
          "curve-style": "bezier",
          "width": 1.4,
          "line-color": "rgba(180,180,200,0.35)",
          "target-arrow-color": "rgba(180,180,200,0.55)",
          "target-arrow-shape": "triangle",
          "arrow-scale": 0.9,
        },
      },
      {
        selector: ":selected",
        style: {
          "background-color": "#d8a32a",
          "border-color": "#ffd76a",
          "border-width": 4,
          "color": "#fff",
        },
      },
      {
        selector: "edge.highlighted",
        style: {
          "line-color": "#ffd76a",
          "target-arrow-color": "#ffd76a",
          "width": 2.5,
        },
      },
    ],
    layout: {
      name: "fcose",
      animate: false,
      nodeSeparation: 80,
      idealEdgeLength: 90,
      nodeRepulsion: 5500,
      gravity: 0.2,
      gravityRangeCompound: 1.5,
      packComponents: true,
      tile: true,
    },
  });

  // Tap a repo node: highlight its edges, scroll its details<details> open
  // in the systems section below so the rest of the panel becomes useful
  // context for the node you picked.
  instance.on("tap", "node", (evt) => {
    const node = evt.target;
    if (node.data("isSystem")) return;
    instance.edges().removeClass("highlighted");
    node.connectedEdges().addClass("highlighted");
    const name = node.data("label");
    const targets = document.querySelectorAll(".catalog-node-name");
    for (const t of targets) {
      if (t.textContent.trim() !== name) continue;
      const det = t.closest("details.catalog-node");
      if (!det) continue;
      det.open = true;
      det.scrollIntoView({ behavior: "smooth", block: "center" });
      break;
    }
  });

  instance.on("tap", (evt) => {
    if (evt.target === instance) {
      instance.edges().removeClass("highlighted");
    }
  });
</script>
{{end}}
